---
const { name = 'YOUR NAME', bio = 'I am a designer and developer passionate about creating bold, memorable digital experiences. With over a decade of experience, I blend editorial design principles with modern web technologies to build things that stand out and stand the test of time.' } = Astro.props;
---

<section id="about" class="py-32 px-6 bg-ink text-paper relative overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute top-0 left-1/2 w-px h-full bg-acid/20 hidden md:block"></div>
  <div class="absolute right-16 top-16 text-[15vw] font-display text-paper/5 select-none pointer-events-none leading-none">
    ?
  </div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24">
      <!-- Left: header -->
      <div>
        <div class="flex items-center gap-6 mb-8">
          <span class="font-mono text-xs tracking-[0.3em] uppercase text-acid">02.</span>
          <h2 class="font-display text-[clamp(3rem,8vw,6rem)] leading-none text-paper">ABOUT<br/>ME</h2>
        </div>
      </div>

      <!-- Right: bio -->
      <div class="space-y-10">
        <p class="font-body text-xl md:text-2xl text-paper/80 leading-relaxed">
          {bio}
        </p>

        <!-- Stats grid -->
        <div class="grid grid-cols-3 gap-4 pt-8">
          <div class="border border-paper/20 p-6 text-center">
            <div class="font-display text-4xl text-acid">10+</div>
            <div class="font-mono text-[10px] tracking-widest uppercase text-paper/50 mt-2">Years Exp</div>
          </div>
          <div class="border border-paper/20 p-6 text-center">
            <div class="font-display text-4xl text-acid">50+</div>
            <div class="font-mono text-[10px] tracking-widest uppercase text-paper/50 mt-2">Projects</div>
          </div>
          <div class="border border-paper/20 p-6 text-center">
            <div class="font-display text-4xl text-acid">15+</div>
            <div class="font-mono text-[10px] tracking-widest uppercase text-paper/50 mt-2">Clients</div>
          </div>
        </div>

        <!-- Quote -->
        <blockquote class="border-l-4 border-acid pl-6 py-2">
          <p class="font-body text-lg italic text-paper/60 leading-relaxed">
            "Good design is as little design as possible — but sometimes, more is more."
          </p>
        </blockquote>
      </div>
    </div>
  </div>
</section>
