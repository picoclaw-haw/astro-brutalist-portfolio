---
const { email = 'hello@example.com', location = 'Venezuela · Remote' } = Astro.props;

const links = [
  { label: 'GitHub', href: '#' },
  { label: 'Twitter / X', href: '#' },
  { label: 'LinkedIn', href: '#' },
  { label: 'Dribbble', href: '#' },
  { label: 'Read.cv', href: '#' },
];
---

<section id="contact" class="py-32 px-6 bg-charcoal text-paper relative overflow-hidden">
  <!-- Grid overlay -->
  <div class="absolute inset-0 grid-bg opacity-10"></div>
  <div class="noise-overlay absolute inset-0"></div>

  <div class="max-w-7xl mx-auto relative z-10">
    <div class="mb-24 flex items-center gap-6">
      <span class="font-mono text-xs tracking-[0.3em] uppercase text-acid">04.</span>
      <h2 class="font-display text-[clamp(3rem,8vw,7rem)] leading-none text-paper">GET IN<br/>TOUCH</h2>
      <div class="flex-1 h-[2px] bg-paper/20 ml-8 hidden md:block"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 md:gap-24">
      <!-- Left: CTA -->
      <div class="space-y-8">
        <p class="font-body text-2xl md:text-3xl text-paper/70 leading-relaxed">
          Got a project?<br/>
          Let's make something<br/>
          <span class="text-acid font-bold">unforgettable.</span>
        </p>

        <a
          href={`mailto:${email}`}
          class="inline-flex items-center gap-3 group font-mono text-sm tracking-[0.3em] uppercase border-2 border-acid text-acid px-8 py-4 hover:bg-acid hover:text-ink transition-all duration-300"
        >
          <span>{email}</span>
          <span class="group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform">↗</span>
        </a>
      </div>

      <!-- Right: Links -->
      <div class="space-y-6">
        <div class="font-mono text-xs tracking-[0.3em] uppercase text-paper/30 mb-6">Find me on</div>
        <div class="space-y-4">
          {links.map(link => (
            <a
              href={link.href}
              class="block group border-b border-paper/10 pb-4 hover:border-acid transition-colors"
            >
              <div class="flex items-center justify-between">
                <span class="font-body text-xl text-paper/80 group-hover:text-acid transition-colors">{link.label}</span>
                <span class="font-mono text-paper/20 group-hover:text-acid group-hover:translate-x-1 group-hover:-translate-y-1 transition-all">→</span>
              </div>
            </a>
          ))}
        </div>

        <div class="pt-8">
          <div class="font-mono text-[10px] tracking-widest uppercase text-paper/30">{location}</div>
        </div>
      </div>
    </div>
  </div>
</section>
